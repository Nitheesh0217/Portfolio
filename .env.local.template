# .env.local — DWS Spatial Portfolio OS
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Use the POOLED connection string (hostname ends in -pooler).
# Project → Connection Details → Pooled connection → copy URL
DATABASE_URL=postgres://your_user:your_password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Anthropic (AI Sidekick) ──────────────────────────────────────────────────
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Public site URL (used for OpenGraph metadataBase) ────────────────────────
NEXT_PUBLIC_SITE_URL=https://dwebstudios.com
